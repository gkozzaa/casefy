# ── Casefy frontend environment ──────────────────────────────────────────────
# Copy to `.env.local` and fill in. Restart `npm run dev` after changes.

# FastAPI interview backend (5_api.py). No trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only, used by the Stripe webhook to upgrade users.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Optional: a pre-created Price for the upgrade. If unset, the price is built
# inline at $19 (see lib/stripe.ts).
STRIPE_PRICE_ID=
# From `stripe listen` or the Dashboard webhook config.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Public site URL (used for Stripe success/cancel redirects in production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
